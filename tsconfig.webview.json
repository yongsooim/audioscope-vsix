{
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2024",
    "lib": [
      "ES2024",
      "DOM",
      "WebWorker"
    ],
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src-webview/**/*.ts",
    "src-webview/**/*.d.ts"
  ]
}
