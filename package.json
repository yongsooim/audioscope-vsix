{
  "name": "audioscope",
  "displayName": "audioscope",
  "description": "Audio waveform and spectrogram viewer playback, zoom, loop",
  "version": "1.0.0",
  "publisher": "yongsooim",
  "repository": {
    "type": "git",
    "url": "https://github.com/yongsooim/wave-scope-vsix.git"
  },
  "homepage": "https://github.com/yongsooim/wave-scope-vsix#readme",
  "bugs": {
    "url": "https://github.com/yongsooim/wave-scope-vsix/issues"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "keywords": [
    "audio",
    "ffmpeg",
    "waveform",
    "spectrogram",
    "mel-spectrogram",
    "scalogram",
    "loudness",
    "ITU-R BS.1770",
    "mp3",
    "wav",
    "wave",
    "flac",
    "m4a",
    "ogg",
    "oga",
    "aac",
    "opus",
    "aif",
    "aiff"
  ],
  "files": [
    "out/*.js",
    "dist/**",
    "src-webview/**/*.css",
    "src-webview/vendor/**/*.mjs",
    "images/*.png",
    "README.md",
    "CHANGELOG.md",
    "FFMPEG_SOURCE.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "src-wasm/third_party/ffmpeg/COPYING.LGPLv2.1",
    "src-wasm/third_party/ffmpeg/COPYING.LGPLv3"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:audioscope.openActiveFileInAudioscope",
    "onCustomEditor:audioscope.editor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "audioscope",
      "properties": {
        "audioscope.openSampleOnStartupInDevelopment": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the bundled sample audio file in audioscope when the extension runs in development mode."
        },
        "audioscope.spectrogramQuality": {
          "type": "string",
          "enum": [
            "balanced",
            "high",
            "max"
          ],
          "default": "high",
          "scope": "resource",
          "description": "Controls spectrogram analysis quality for audioscope. Higher presets request denser time/frequency detail."
        },
        "audioscope.spectrogramDefaults": {
          "type": "object",
          "scope": "window",
          "additionalProperties": false,
          "default": {
            "analysisType": "spectrogram",
            "colormapDistribution": "balanced",
            "fftSize": 4096,
            "frequencyScale": "log",
            "maxDecibels": 0,
            "melBandCount": 256,
            "mfccCoefficientCount": 20,
            "mfccMelBandCount": 128,
            "minDecibels": -80,
            "overlapRatio": 0.75,
            "scalogramHopSamples": 0,
            "scalogramMaxFrequency": 20000,
            "scalogramMinFrequency": 50,
            "scalogramOmega0": 6,
            "scalogramRowDensity": 1,
            "windowFunction": "hann"
          },
          "description": "Stores the default audioscope spectrogram settings that new files open with.",
          "properties": {
            "analysisType": {
              "type": "string",
              "enum": ["spectrogram", "mel", "mfcc", "scalogram", "chroma"]
            },
            "colormapDistribution": {
              "type": "string",
              "enum": ["balanced", "contrast", "soft"]
            },
            "fftSize": {
              "type": "number",
              "enum": [1024, 2048, 4096, 8192, 16384]
            },
            "frequencyScale": {
              "type": "string",
              "enum": ["log", "mixed", "linear"]
            },
            "maxDecibels": {
              "type": "number"
            },
            "melBandCount": {
              "type": "number",
              "enum": [128, 256, 512]
            },
            "mfccCoefficientCount": {
              "type": "number",
              "enum": [13, 20, 32, 40]
            },
            "mfccMelBandCount": {
              "type": "number",
              "enum": [128, 256, 512]
            },
            "minDecibels": {
              "type": "number"
            },
            "overlapRatio": {
              "type": "number",
              "enum": [0.5, 0.75, 0.875, 0.9375]
            },
            "scalogramHopSamples": {
              "type": "number",
              "enum": [0, 256, 512, 1024, 2048, 4096]
            },
            "scalogramMaxFrequency": {
              "type": "number"
            },
            "scalogramMinFrequency": {
              "type": "number"
            },
            "scalogramOmega0": {
              "type": "number",
              "enum": [4, 5, 6, 7, 8, 10, 12]
            },
            "scalogramRowDensity": {
              "type": "number",
              "enum": [0.5, 0.75, 1, 1.5, 2, 3, 4]
            },
            "windowFunction": {
              "type": "string",
              "enum": ["hann", "hamming", "blackman", "rectangular"]
            }
          }
        }
      }
    },
    "commands": [
      {
        "command": "audioscope.openActiveFileInAudioscope",
        "title": "Open Active Audio File in audioscope",
        "category": "audioscope"
      }
    ],
    "customEditors": [
      {
        "viewType": "audioscope.editor",
        "displayName": "audioscope",
        "selector": [
          {
            "filenamePattern": "*.wav"
          },
          {
            "filenamePattern": "*.wave"
          },
          {
            "filenamePattern": "*.mp3"
          },
          {
            "filenamePattern": "*.ogg"
          },
          {
            "filenamePattern": "*.oga"
          },
          {
            "filenamePattern": "*.flac"
          },
          {
            "filenamePattern": "*.m4a"
          },
          {
            "filenamePattern": "*.aac"
          },
          {
            "filenamePattern": "*.opus"
          },
          {
            "filenamePattern": "*.aif"
          },
          {
            "filenamePattern": "*.aiff"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "clean": "node -e \"const fs=require('node:fs'); for (const dir of ['dist','out']) fs.rmSync(dir,{recursive:true,force:true});\"",
    "build:embedded-media-tools": "tsx ./scripts/build-embedded-media-tools.mts",
    "build:wasm-core": "tsx ./scripts/build-wasm.mts",
    "build:webview": "tsx ./scripts/build-webview.mts",
    "compile": "bun run clean && bun run build:embedded-media-tools && bun run build:wasm-core && bun run build:webview && tsc -p ./ && tsc -p ./tsconfig.webview.json && tsc -p ./tsconfig.scripts.json",
    "watch": "tsc -w -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.100.0",
    "rolldown": "^1.0.0-rc.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
