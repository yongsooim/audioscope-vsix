{
  "name": "wave-scope",
  "displayName": "Wave Scope",
  "description": "Audio waveform and spectrogram editor for VS Code with playback, zoom, and loop controls.",
  "version": "1.0.0",
  "publisher": "yongsooim",
  "repository": {
    "type": "git",
    "url": "https://github.com/yongsooim/wave-scope-vsix.git"
  },
  "homepage": "https://github.com/yongsooim/wave-scope-vsix#readme",
  "bugs": {
    "url": "https://github.com/yongsooim/wave-scope-vsix/issues"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "keywords": [
    "audio",
    "waveform",
    "spectrogram",
    "mp3",
    "wav",
    "flac"
  ],
  "files": [
    "out/extension.js",
    "out/externalAudioTools.js",
    "out/waveScopeEditor.js",
    "dist/**",
    "src-webview/**/*.css",
    "src-webview/vendor/**/*.mjs",
    "images/*.png",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Wave Scope",
      "properties": {
        "waveScope.openSampleOnStartupInDevelopment": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the bundled sample audio file in Wave Scope when the extension runs in development mode."
        },
        "waveScope.spectrogramQuality": {
          "type": "string",
          "enum": [
            "balanced",
            "high",
            "max"
          ],
          "default": "high",
          "scope": "resource",
          "description": "Controls spectrogram analysis quality for Wave Scope. Higher presets request denser time/frequency detail."
        },
        "waveScope.ffmpegPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional path or command name for the ffmpeg executable. Leave empty to resolve ffmpeg from PATH."
        },
        "waveScope.ffprobePath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional path or command name for the ffprobe executable. Leave empty to resolve ffprobe from PATH."
        }
      }
    },
    "commands": [
      {
        "command": "waveScope.openActiveFileInWaveScope",
        "title": "Open Active Audio File in Wave Scope",
        "category": "Wave Scope"
      }
    ],
    "customEditors": [
      {
        "viewType": "waveScope.editor",
        "displayName": "Wave Scope",
        "selector": [
          {
            "filenamePattern": "*.wav"
          },
          {
            "filenamePattern": "*.wave"
          },
          {
            "filenamePattern": "*.mp3"
          },
          {
            "filenamePattern": "*.ogg"
          },
          {
            "filenamePattern": "*.oga"
          },
          {
            "filenamePattern": "*.flac"
          },
          {
            "filenamePattern": "*.m4a"
          },
          {
            "filenamePattern": "*.aac"
          },
          {
            "filenamePattern": "*.opus"
          },
          {
            "filenamePattern": "*.aif"
          },
          {
            "filenamePattern": "*.aiff"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "clean": "node -e \"const fs=require('node:fs'); for (const dir of ['dist','out']) fs.rmSync(dir,{recursive:true,force:true});\"",
    "build:wave-core": "zig build wave-core-artifacts",
    "build:webview": "tsx ./scripts/build-webview.mts",
    "compile": "bun run clean && bun run build:wave-core && bun run build:webview && tsc -p ./ && tsc -p ./tsconfig.webview.json && tsc -p ./tsconfig.scripts.json",
    "watch": "tsc -w -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.100.0",
    "rolldown": "^1.0.0-rc.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
