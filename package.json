{
  "name": "wave-scope",
  "displayName": "Wave Scope",
  "description": "VS Code custom audio editor with waveform, spectrogram, and playback controls.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Wave Scope",
      "properties": {
        "waveScope.openSampleOnStartupInDevelopment": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the bundled sample audio file in Wave Scope when the extension runs in development mode."
        },
        "waveScope.spectrogramQuality": {
          "type": "string",
          "enum": [
            "balanced",
            "high",
            "max"
          ],
          "default": "high",
          "scope": "resource",
          "description": "Controls spectrogram analysis quality for Wave Scope. Higher presets request denser time/frequency detail."
        },
        "waveScope.ffmpegPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional path or command name for the ffmpeg executable. Leave empty to resolve ffmpeg from PATH."
        },
        "waveScope.ffprobePath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional path or command name for the ffprobe executable. Leave empty to resolve ffprobe from PATH."
        }
      }
    },
    "commands": [
      {
        "command": "waveScope.openActiveAudioPreview",
        "title": "Open Active Audio File in Wave Scope",
        "category": "Wave Scope"
      }
    ],
    "customEditors": [
      {
        "viewType": "waveScope.audioPreview",
        "displayName": "Wave Scope",
        "selector": [
          {
            "filenamePattern": "*.wav"
          },
          {
            "filenamePattern": "*.wave"
          },
          {
            "filenamePattern": "*.mp3"
          },
          {
            "filenamePattern": "*.ogg"
          },
          {
            "filenamePattern": "*.oga"
          },
          {
            "filenamePattern": "*.flac"
          },
          {
            "filenamePattern": "*.m4a"
          },
          {
            "filenamePattern": "*.aac"
          },
          {
            "filenamePattern": "*.opus"
          },
          {
            "filenamePattern": "*.aif"
          },
          {
            "filenamePattern": "*.aiff"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "build:wave-core": "zig build wave-core-artifacts",
    "build:webview": "tsx ./scripts/build-webview.mts",
    "compile": "bun run build:wave-core && bun run build:webview && tsc -p ./ && tsc -p ./tsconfig.webview.json && tsc -p ./tsconfig.scripts.json",
    "watch": "tsc -w -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.100.0",
    "rolldown": "^1.0.0-rc.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
